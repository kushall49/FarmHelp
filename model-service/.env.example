# Environment Configuration for Flask ML Service

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
HOST=0.0.0.0
PORT=5000

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:4000,http://localhost:19000,http://localhost:3000

# Model Configuration
MODEL_PATH=models/plant_disease_model.h5
MODEL_TYPE=h5
TOP_K_PREDICTIONS=3

# Image Processing
MAX_IMAGE_SIZE_MB=10

# GradCAM
ENABLE_GRADCAM=True
GRADCAM_LAYER=top_conv

# Logging
LOG_LEVEL=INFO

# Performance
MAX_WORKERS=4
REQUEST_TIMEOUT=30
