              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": true,\n  \"analysisId\": \"67359a1b2c4d8e9f01234567\",\n  \"crop\": \"Tomato\",\n  \"disease\": \"Late Blight\",\n  \"confidence\": 0.94,\n  \"confidencePercentage\": 94,\n  \"predictions\": [\n    {\n      \"disease\": \"Late Blight\",\n      \"confidence\": 0.94,\n      \"rank\": 1\n    },\n    {\n      \"disease\": \"Early Blight\",\n      \"confidence\": 0.04,\n      \"rank\": 2\n    }\n  ],\n  \"recommendations\": {\n    \"summary\": \"Late blight is a serious fungal disease that affects tomatoes. Act quickly to prevent spread.\",\n    \"symptoms\": [\n      \"Water-soaked spots on leaves\",\n      \"White fungal growth on undersides\",\n      \"Brown lesions on stems\"\n    ],\n    \"treatments\": {\n      \"organic\": [\n        \"Copper-based fungicides\",\n        \"Neem oil spray\",\n        \"Remove infected plants immediately\"\n      ],\n      \"chemical\": [\n        \"Chlorothalonil\",\n        \"Mancozeb\"\n      ],\n      \"preventive\": [\n        \"Avoid overhead watering\",\n        \"Improve air circulation\",\n        \"Rotate crops annually\"\n      ]\n    },\n    \"urgency\": \"low\"\n  },\n  \"fertilizers\": {\n    \"recommended\": [\n      {\n        \"id\": \"1\",\n        \"name\": \"NPK 20-20-20\",\n        \"dosage\": \"25g/plant\",\n        \"notes\": \"General purpose balanced fertilizer. Apply every 2 weeks.\",\n        \"legalStatus\": \"OK\",\n        \"safetyWarning\": \"Wear gloves during application. Keep away from children.\",\n        \"applicationMethod\": \"Soil application - water in thoroughly\"\n      },\n      {\n        \"id\": \"2\",\n        \"name\": \"Copper Fungicide\",\n        \"dosage\": \"2-3 tbsp/gallon\",\n        \"notes\": \"Mix with water and spray on affected plants. Apply every 7-10 days.\",\n        \"legalStatus\": \"OK\",\n        \"safetyWarning\": \"Avoid contact with skin. Wash hands after use.\",\n        \"applicationMethod\": \"Spray application - cover all plant surfaces\"\n      },\n      {\n        \"id\": \"3\",\n        \"name\": \"Neem Oil\",\n        \"dosage\": \"10ml/L\",\n        \"notes\": \"Organic fungicide. Spray on leaves in evening. Repeat weekly.\",\n        \"legalStatus\": \"OK\",\n        \"safetyWarning\": \"Safe for organic farming. May cause skin irritation.\",\n        \"applicationMethod\": \"Spray application - evening application preferred\"\n      }\n    ],\n    \"disclaimer\": \"⚠️ DISCLAIMER: These recommendations are for informational purposes only. Always consult with a licensed agricultural expert or extension service before applying any chemicals or fertilizers. Follow all local regulations and safety guidelines. Read product labels carefully and use personal protective equipment.\",\n    \"additionalAdvice\": [\n      \"Monitor plants regularly for early detection\",\n      \"Remove and destroy infected plant material\",\n      \"Ensure proper spacing for air circulation\",\n      \"Apply fungicides preventively, not after infection\",\n      \"Avoid overhead irrigation to reduce leaf wetness\"\n    ]\n  },\n  \"gradcam\": \"data:image/jpeg;base64,/9j/4AAQSkZJRgABAQAA...\",\n  \"processingTimeMs\": 3247,\n  \"status\": \"completed\",\n  \"needsExpertReview\": false\n}"
