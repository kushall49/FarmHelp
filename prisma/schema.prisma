generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  avatar    String?
  bio       String?
  
  // Verification fields
  isVerifiedFarmer    Boolean @default(false)
  isVerifiedProvider  Boolean @default(false)
  averageRating       Float   @default(0)
  
  posts              Post[]
  comments           Comment[]
  serviceListings    ServiceListing[] @relation("ServiceProvider")
  jobRequests        JobRequest[]     @relation("JobRequester")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String    @id @default(cuid())
  content   String
  imageUrl  String?
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments  Comment[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceListing {
  id          String   @id @default(cuid())
  providerId  String
  provider    User     @relation("ServiceProvider", fields: [providerId], references: [id], onDelete: Cascade)
  
  serviceType String
  title       String
  
  district    String
  taluk       String
  
  phoneNumber String
  rate        String
  description String?
  
  images      Json
  isAvailable Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([district, serviceType])
}

model JobRequest {
  id             String   @id @default(cuid())
  farmerId       String
  farmer         User     @relation("JobRequester", fields: [farmerId], references: [id], onDelete: Cascade)
  
  serviceNeeded  String
  
  district       String
  taluk          String
  
  dateNeeded     DateTime
  description    String
  isOpen         Boolean  @default(true)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  @@index([district, serviceNeeded])
}