const axios = require('axios');

// Hugging Face API Configuration
const HUGGINGFACE_API_KEY = process.env.HUGGINGFACE_API_KEY || '';
const HUGGINGFACE_API_URL = 'https://api-inference.huggingface.co/models';

// Using Mixtral model which works well on free tier
const CHAT_MODEL = process.env.CHAT_MODEL || 'mistralai/Mixtral-8x7B-Instruct-v0.1';

const AIService = {
  /**
   * Analyze plant image buffer
   * For now returns mock data - can be enhanced with vision models like:
   * - "Salesforce/blip-image-captioning-base" for image understanding
   * - Custom plant disease detection models from HF Hub
   */
  async analyzePlant(buffer) {
    if (!HUGGINGFACE_API_KEY) {
      console.log('[AI] No API key - returning mock plant analysis');
      return {
        disease: 'Leaf Spot',
        confidence: 0.75,
        recommendations: 'Apply copper-based fungicide. Remove affected leaves. Ensure proper spacing for air circulation.',
        treatment: 'Spray with neem oil solution every 7 days for 3 weeks. Reduce overhead watering.'
      };
    }

    // TODO: Implement actual vision model integration
    // Example: BLIP, ViT, or custom plant disease models from Hugging Face
    return {
      disease: 'Healthy Plant',
      confidence: 0.85,
      recommendations: 'Continue current care routine.',
      treatment: 'No treatment needed.'
    };
  },

  /**
   * Chat with farming assistant using Hugging Face models
   * This uses conversational AI models fine-tuned for dialogue
   */
  async chat(message) {
    if (!HUGGINGFACE_API_KEY) {
      console.log('[AI] No API key - returning mock chat response');
      return this.getMockFarmingResponse(message);
    }

    try {
      console.log(`[AI] Sending message to ${CHAT_MODEL}:`, message);

      // Create farming-focused prompt
      const farmingPrompt = `You are an expert farming assistant. Answer this farming question concisely and practically: ${message}`;

      const response = await axios.post(
        `${HUGGINGFACE_API_URL}/${CHAT_MODEL}`,
        {
          inputs: farmingPrompt,
          parameters: {
            max_length: 200,
            min_length: 20,
            temperature: 0.7,
            do_sample: true
          }
        },
        {
          headers: {
            'Authorization': `Bearer ${HUGGINGFACE_API_KEY}`,
            'Content-Type': 'application/json'
          },
          timeout: 30000 // 30 second timeout
        }
      );

      console.log('[AI] Received response from Hugging Face');
      console.log('[AI] Response data:', JSON.stringify(response.data, null, 2));

      // Handle different response formats from various models
      let reply = '';
      
      if (Array.isArray(response.data)) {
        // Most HF models return array format
        reply = response.data[0]?.generated_text || response.data[0]?.text || response.data[0]?.translation_text || '';
      } else if (response.data.generated_text) {
        reply = response.data.generated_text;
      } else if (response.data[0]) {
        reply = response.data[0];
      } else if (typeof response.data === 'string') {
        reply = response.data;
      }

      // Clean up the response
      reply = reply.trim();
      
      // If response is empty or too short, return mock response
      if (!reply || reply.length < 10) {
        console.log('[AI] Response too short, using mock response');
        return this.getMockFarmingResponse(message);
      }

      return reply;

    } catch (error) {
      console.error('[AI ERROR] Full error:', error.message);
      console.error('[AI ERROR] Response:', error.response?.data);
      console.error('[AI ERROR] Status:', error.response?.status);
      
      // If model is loading, inform user
      if (error.response?.status === 503) {
        console.log('[AI] Model loading, asking user to wait');
        return '🔄 The AI model is loading (takes ~20-30 seconds on first use). Please try again in a moment!';
      }

      // If unauthorized or forbidden
      if (error.response?.status === 401 || error.response?.status === 403) {
        console.log('[AI] API key issue, using mock response');
        return '⚠️ API authentication issue. Using offline mode. ' + this.getMockFarmingResponse(message);
      }

      // If rate limited or other error, use mock response
      console.log('[AI] Using mock response due to error');
      return this.getMockFarmingResponse(message);
    }
  },

  /**
   * Mock farming responses for when API is not available
   * Provides helpful farming information based on keywords
   */
  getMockFarmingResponse(message) {
    const msg = message.toLowerCase();

    // Crop recommendations
    if (msg.includes('crop') || msg.includes('plant') || msg.includes('grow')) {
      return '🌾 For Indian conditions, consider crops like rice, wheat, cotton, sugarcane, or pulses based on your soil type and season. Loamy soil is great for most crops. What\'s your soil type and location?';
    }

    // Soil queries
    if (msg.includes('soil') || msg.includes('fertilizer')) {
      return '🌱 Healthy soil is key! Test your soil pH (ideal: 6-7). Add organic compost regularly. For fertilizers, use NPK based on crop needs. Loamy soil is best for most crops, clay retains water, sandy drains fast.';
    }

    // Pest control
    if (msg.includes('pest') || msg.includes('insect') || msg.includes('bug')) {
      return '🐛 Natural pest control: Use neem oil spray (organic), introduce beneficial insects, practice crop rotation, and maintain field hygiene. For serious infestations, consult local agricultural officer for appropriate pesticides.';
    }

    // Disease queries
    if (msg.includes('disease') || msg.includes('leaf') || msg.includes('spot')) {
      return '🍃 Common plant diseases: Leaf spot (fungus - use copper fungicide), powdery mildew (improve air flow), root rot (reduce watering). Remove infected parts. Ensure proper spacing and drainage.';
    }

    // Water/irrigation
    if (msg.includes('water') || msg.includes('irrigation') || msg.includes('rain')) {
      return '💧 Water management: Drip irrigation saves 40% water. Water early morning/evening. Check soil moisture 2-3 inches deep. Most crops need 1-2 inches per week. In monsoon, ensure proper drainage.';
    }

    // Weather
    if (msg.includes('weather') || msg.includes('season') || msg.includes('temperature')) {
      return '🌦️ India has 3 main farming seasons: Kharif (June-Oct, monsoon crops), Rabi (Oct-March, winter crops), and Zaid (March-June, summer crops). Plan crops according to your region\'s weather patterns.';
    }

    // Fertilizer
    if (msg.includes('fertiliz') || msg.includes('manure') || msg.includes('npk')) {
      return '🌿 Fertilizer tips: NPK ratio varies by crop. Nitrogen (N) for leaves, Phosphorus (P) for roots, Potassium (K) for fruits. Organic options: cow dung, vermicompost, green manure. Apply based on soil test.';
    }

    // Seeds
    if (msg.includes('seed') || msg.includes('variety')) {
      return '🌱 Use certified seeds from authorized dealers. Choose varieties suited to your climate. Hybrid seeds give better yield but can\'t be reused. Traditional varieties are more resilient. Store seeds in cool, dry place.';
    }

    // General farming advice
    return '👨‍🌾 I\'m FarmBot, your farming assistant! I can help with crops, soil, pests, irrigation, weather, and more. Ask me specific questions like "Best crops for loamy soil?" or "How to control aphids?" What would you like to know?';
  }
};

module.exports = AIService;
