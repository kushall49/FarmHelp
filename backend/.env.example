# ─── Server ───────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ─── Database ─────────────────────────────────────────────
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# ─── Auth ─────────────────────────────────────────────────
# Generate a strong random string (e.g. openssl rand -hex 64)
JWT_SECRET=your_jwt_secret_here

# ─── Cloudinary (image storage) ───────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Groq (AI chatbot) ────────────────────────────────────
GROQ_API_KEY=your_groq_api_key

# ─── ML Service ───────────────────────────────────────────
# URL of the Python Flask model microservice
FLASK_SERVICE_URL=http://localhost:5000

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# On Render, add your Vercel app URL here
# Example: https://your-app.vercel.app,http://localhost:19006
ALLOWED_ORIGINS=http://localhost:19006,http://localhost:8081

# ─── Firebase Admin (optional, for push notifications) ─────
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR-PRIVATE-KEY\n-----END PRIVATE KEY-----\n"
